{
  "name": "@brownmotie/styled-text-react",
  "version": "1.0.6",
  "description": "Flexible library to convert a text with custom markup to html (or anything else).",
  "author": "brownmotie",
  "license": "MIT",
  "readme": "README.md",
  "repository": {
    "type": "git",
    "url": "https://github.com/TheBrownMotie/styled-text.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "commonjs",
  "dependencies": {
    "@brownmotie/styled-text": "^1.0.2"
  },
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "devDependencies": {
    "@types/node": "^25.9.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "typescript": "^6.0.3",
    "vite": "^8.0.13",
    "vite-plugin-dts": "^5.0.1"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "styled-text": "*"
  },
  "scripts": {
    "build": "vite build"
  }
}
