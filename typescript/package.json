{
  "name": "@brownmotie/styled-text",
  "version": "1.4.0",
  "description": "Flexible library to convert a text with custom markup to html (or anything else).",
  "author": "brownmotie",
  "license": "MIT",
  "readme": "README.md",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/TheBrownMotie/styled-text.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "devDependencies": {
    "tsup": "^8.5.1",
    "vitest": "^4.1.6"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "test": "vitest"
  }
}
